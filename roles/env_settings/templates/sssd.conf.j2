# {{ ansible_managed_header }}
# {{ ansible_managed_warning }}

{# Merge base configuration with host-specific overrides #}
{% set sssd_domains_base = sssd_domains | default({}) %}
{% set sssd_domains_overrides = sssd_domains_overrides | default({}) %}
{% set sssd_domains = sssd_domains_base | combine(sssd_domains_overrides, recursive=True) %}

[sssd]
domains = {{ sssd_domains.keys() | join(', ') }}
services = {{ sssd_services | default('nss, pam') }}
config_file_version = 2

[nss]
homedir_substring = /home

{% for domain_name, domain in sssd_domains.items() %}

[domain/{{ domain_name }}]
{% for key, value in domain.items() %}
{% if value is not none and value != '' %}
{% if value is boolean %}
{{ key }} = {{ 'True' if value else 'False' }}
{% else %}
{{ key }} = {{ value }}
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}