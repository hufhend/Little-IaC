#   {{ ansible_managed_header }}
#   {{ ansible_managed_warning }}

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Logo color (default: RED, can be changed via motd_logo_color variable)
LOGO_COLOR="${{ '{' }}{{ motd_logo_color | default('RED') }}}"

{% raw %}
# --- ASCII Art Logo ---
echo -e "${LOGO_COLOR}"
cat << "EOF"
{% endraw %}
{{ motd_ascii_logo }}
{% raw %}
EOF
echo -e "${NC}"

# Server name (zarovnáno jako ostatní labely)
echo -e "${BOLD}Server name:${NC}   ${GREEN}$(hostname)${NC}"

# --- System Information ---
# Get OS info for packages line
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS_NAME="$NAME"
    OS_VERSION="$VERSION_ID"
    OS_CODENAME="$VERSION_CODENAME"
fi

# Packages count with OS info
if command -v rpm &> /dev/null; then
    PACKAGES=$(rpm -qa --last | wc -l)
    PKG_TEXT="${PACKAGES} on ${OS_NAME} ${OS_VERSION}${OS_CODENAME:+ ($OS_CODENAME)}"
elif command -v dpkg &> /dev/null; then
    PACKAGES=$(dpkg -l | grep '^ii' | wc -l)
    PKG_TEXT="${PACKAGES} on ${OS_NAME} ${OS_VERSION}${OS_CODENAME:+ ($OS_CODENAME)}"
else
    PKG_TEXT="N/A"
fi
echo -e "${BOLD}Packages:${NC}      ${GREEN}${PKG_TEXT}${NC}"

# Support information
{% endraw %}
echo -e "${BOLD}Support:${NC}       ${GREEN}{{ motd_support_line1 | default('Best Effort for Everyone') }}${NC}"
{% if motd_support_line2 is defined %}
echo -e "               ${GREEN}{{ motd_support_line2 }}${NC}"
{% endif %}
{% raw %}

# IP addresses
IPv4_LIST=$(ip -4 addr show | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v '^127\.' | sort -u | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
echo -e "${BOLD}IPv4:${NC}          ${GREEN}(LAN) ${IPv4_LIST}${NC}"

# Containers - dynamic detection, only shown if user has access
if command -v docker &> /dev/null && docker ps -q 2>/dev/null | grep -q .; then
    CONTAINERS=$(docker ps --format "{{.Names}}" | tr '\n' ',' | sed 's/,/, /g' | sed 's/, $//')
    echo -e "${BOLD}Containers:${NC}    ${GREEN}${CONTAINERS}${NC}"
elif command -v podman &> /dev/null && podman ps -q 2>/dev/null | grep -q .; then
    CONTAINERS=$(podman ps --format "{{.Names}}" | tr '\n' ',' | sed 's/,/, /g' | sed 's/, $//')
    echo -e "${BOLD}Containers:${NC}    ${GREEN}${CONTAINERS}${NC}"
fi

echo ""

# --- Performance section ---
echo -e "${GRAY}${BOLD}Performance:${NC}"
echo -e "${GRAY}"

# System load and Processes - first line
LOAD=$(cat /proc/loadavg | awk '{print $1}')
CORES=$(nproc)
LOAD_PERCENT=$(echo "$LOAD $CORES" | awk '{printf "%.0f", ($1/$2)*100}')
PROCESSES=$(ps -e | wc -l)

echo -e "${GRAY} System load:  ${GREEN}${LOAD_PERCENT}%${NC}${GRAY}            \t Processes:    ${GREEN}${PROCESSES}${NC}"

# Memory and Swap - second line
MEM_TOTAL=$(free -m | awk '/^Mem:/ {print $2}')
MEM_USED=$(free -m | awk '/^Mem:/ {print $3}')
MEM_PERCENT=$((MEM_USED * 100 / MEM_TOTAL))
MEM_STRING="${MEM_PERCENT}% of ${MEM_TOTAL}M"

SWAP_TOTAL=$(free -m | awk '/^Swap:/ {print $2}')
if [ $SWAP_TOTAL -gt 0 ]; then
    SWAP_USED=$(free -m | awk '/^Swap:/ {print $3}')
    SWAP_PERCENT=$((SWAP_USED * 100 / SWAP_TOTAL))
    SWAP_STRING="${SWAP_PERCENT}% of ${SWAP_TOTAL}M"
else
    SWAP_STRING="0% of 0M"
fi

MEM_LENGTH=${#MEM_STRING}
if [ $MEM_LENGTH -lt 15 ]; then
    SPACES=$((15 - MEM_LENGTH))
    PADDING=$(printf '%*s' $SPACES '')
else
    PADDING=" "
fi
echo -e "${GRAY} Memory usage: ${GREEN}${MEM_STRING}${NC}${GRAY}${PADDING}\t Swap usage:   ${GREEN}${SWAP_STRING}${NC}"

# Disk and Uptime - third line
DISK_USAGE=$(df -h / | awk 'NR==2 {print $5}' | sed 's/%//')
DISK_TOTAL=$(df -h / | awk 'NR==2 {print $2}')
DISK_STRING="${DISK_USAGE}% of ${DISK_TOTAL}"

# Uptime - without weeks, only days, hours, minutes
UPTIME_SECONDS=$(cat /proc/uptime | awk '{print int($1)}')
DAYS=$((UPTIME_SECONDS / 86400))
HOURS=$(( (UPTIME_SECONDS % 86400) / 3600 ))
MINUTES=$(( (UPTIME_SECONDS % 3600) / 60 ))

UPTIME_CLEAN="${DAYS} days, ${HOURS} hours, ${MINUTES} minutes"

DISK_LENGTH=${#DISK_STRING}
if [ $DISK_LENGTH -lt 15 ]; then
    DISK_SPACES=$((15 - DISK_LENGTH))
    DISK_PADDING=$(printf '%*s' $DISK_SPACES '')
else
    DISK_PADDING=" "
fi

echo -e "${GRAY} Disk usage:   ${GREEN}${DISK_STRING}${NC}${GRAY}${DISK_PADDING}\t Uptime:       ${GREEN}${UPTIME_CLEAN}${NC}"
echo -e "${NC}"

# --- News section ---
{% endraw %}
{% if motd_news is defined %}
echo -e "${BOLD}News:${NC}          ${GREEN}{{ motd_news }}${NC}"
echo ""
{% endif %}