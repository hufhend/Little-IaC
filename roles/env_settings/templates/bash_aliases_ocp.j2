#   {{ ansible_managed_header }}
#   {{ ansible_managed_warning }}
#   Generated for user: {{ user_item }}

{% for cluster_id, cluster in ocp_clusters.items() %}

ocl-{{ cluster_id }}() {
    export OCP_CLUSTER_URL="{{ cluster.url }}"
    export OCP_USERNAME="{{ user_item }}"
    export KUBECONFIG=~/.kube/{{ cluster.config }}
    echo "{{ cluster.emoji }} OpenShift {{ cluster.name }}: $OCP_CLUSTER_URL"
    echo "👤 User: $OCP_USERNAME"
{% if cluster.region is defined %}
    echo "🌍 Region: {{ cluster.region }}"
{% endif %}
{% if cluster.environment is defined %}
    echo "🏷️  Environment: {{ cluster.environment }}"
{% endif %}
    ocp-login
}

ocl-{{ cluster_id }}-quick() {
    export OCP_CLUSTER_URL="{{ cluster.url }}"
    export OCP_USERNAME="{{ user_item }}"
    export KUBECONFIG=~/.kube/{{ cluster.config }}
    echo "{{ cluster.emoji }} OpenShift {{ cluster.name }} - Quick login"
{% if cluster.region is defined %}
    echo "🌍 Region: {{ cluster.region }}"
{% endif %}
    ocp-login --quick
}

ocl-{{ cluster_id }}-status() {
    export KUBECONFIG=~/.kube/{{ cluster.config }}
    echo "{{ cluster.emoji }} OpenShift {{ cluster.name }} - Status check"
    ocp-login --status
}

{% endfor %}
